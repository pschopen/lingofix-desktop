{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lingofix Desktop",
  "identifier": "com.lingofix.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Lingofix Desktop",
        "width": 1280,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost https: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*",
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "externalBin": [
      "binaries/lingofix-backend"
    ],
    "resources": {
      "resources/word-compare.scpt": "word-compare.scpt",
      "resources/binaries/word-compare.scpt": "binaries/word-compare.scpt",
      "resources/libreoffice-compare.py": "libreoffice-compare.py",
      "resources/binaries/libreoffice-compare.py": "binaries/libreoffice-compare.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
