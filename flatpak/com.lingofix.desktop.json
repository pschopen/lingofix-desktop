{
  "app-id": "com.lingofix.desktop",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.node20"
  ],
  "command": "lingofix-desktop",
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/node20/bin",
    "env": {
      "CARGO_HOME": "/run/build/lingofix-desktop/.cargo",
      "XDG_CACHE_HOME": "/run/build/lingofix-desktop/.cache",
      "npm_config_cache": "/run/build/lingofix-desktop/.npm"
    }
  },
  "finish-args": [
    "--share=network",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--device=dri",
    "--filesystem=host",
    "--talk-name=org.freedesktop.FileManager1"
  ],
  "modules": [
    {
      "name": "lingofix-desktop",
      "buildsystem": "simple",
      "build-commands": [
        "npm ci --prefix frontend",
        "npm run build --prefix frontend",
        "cargo build --manifest-path tauri/Cargo.toml --release --target x86_64-unknown-linux-gnu",
        "install -Dm755 tauri/target/x86_64-unknown-linux-gnu/release/lingofix-desktop /app/bin/lingofix-desktop",
        "install -Dm755 tauri/binaries/lingofix-backend-x86_64-unknown-linux-gnu /app/bin/binaries/lingofix-backend",
        "install -Dm644 tauri/resources/binaries/libreoffice-compare.py /app/bin/binaries/libreoffice-compare.py",
        "install -Dm644 tauri/resources/binaries/word-compare.scpt /app/bin/binaries/word-compare.scpt",
        "install -Dm644 flatpak/com.lingofix.desktop.desktop /app/share/applications/com.lingofix.desktop.desktop",
        "install -Dm644 flatpak/com.lingofix.desktop.metainfo.xml /app/share/metainfo/com.lingofix.desktop.metainfo.xml",
        "install -Dm644 tauri/icons/128x128.png /app/share/icons/hicolor/128x128/apps/com.lingofix.desktop.png"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
